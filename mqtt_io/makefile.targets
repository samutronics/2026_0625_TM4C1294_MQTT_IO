# makefile.targets — post-build hook for the mqtt_io CCS project.
#
# Debug/makefile includes this file via "-include ../makefile.targets" and is
# auto-generated by CCS (so editing it directly is fragile).  This file lives
# in the project root, is checked into git, and survives CCS regeneration.
#
# Effect: every successful link triggers post_build.ps1 which converts
# mqtt_io.out to a timestamped mqtt_io_YYYYMMDDHHMM.bin and a fixed
# mqtt_io.bin in the same Debug/ directory.

# Pin the default goal.  The buildinfo.o:FORCE rule below otherwise steals the
# default goal, so a bare "gmake" would only rebuild buildinfo.o and never link
# or run post_build — producing a silently stale binary.  Always build 'all'.
.DEFAULT_GOAL := all

.PHONY: post_binary FORCE

# FORCE makes buildinfo.o always recompile so the displayed fwver timestamp
# reflects the actual build time, not the last time enet_io.c was touched.
FORCE:
buildinfo.o: FORCE

# Extend the top-level 'all' target to run the binary export step.
all: post_binary

# post_binary depends on the ELF so the script only runs after a successful link.
# The recipe executes from the Debug/ directory, so "../" resolves to the project root.
post_binary: mqtt_io.out
	@powershell -NoProfile -ExecutionPolicy Bypass -File "../post_build.ps1"
